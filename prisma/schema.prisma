generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Item {
  id     String @id @default(uuid())
  name   String
  weight Int
  imageUrl String?
  sortOrder Int     @default(0)
}

model LimitPreset {
  id        String @id @default(uuid())
  name      String
  maxWeight Int
  sortOrder Int     @default(0)
}